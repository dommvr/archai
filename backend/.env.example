# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── JWT verification ──────────────────────────────────────────
# Primary path (ES256 / RS256 — current Supabase default):
#   No secret needed. Public keys are fetched automatically from:
#   {SUPABASE_URL}/auth/v1/.well-known/jwks.json
#   Override only if your Supabase project uses a non-standard JWKS URL:
# SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
#
# Legacy fallback (HS256 — older Supabase projects / transition window):
#   Set this only if you still need to accept tokens signed with the old
#   shared secret. Leave unset to hard-disable the HS256 path.
#   Find in: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
# SUPABASE_JWT_SECRET=your-jwt-secret

# ── App ───────────────────────────────────────────────────────
# Origin of the Next.js frontend (for CORS)
APP_FRONTEND_URL=http://localhost:3000
# Port FastAPI listens on
APP_PORT=8000
# Log level: debug | info | warning | error
LOG_LEVEL=info

# ── Site Data Providers ───────────────────────────────────────
# V1: Nominatim (OpenStreetMap) is used by default — no key needed.
# Swap to a paid provider by setting these:
#
# Regrid (parcel data) — https://regrid.com
# REGRID_API_KEY=
#
# Zoneomics (zoning data) — https://zoneomics.com
# ZONEOMICS_API_KEY=

# ── Document Ingestion ────────────────────────────────────────
# Supabase Storage bucket name for uploaded documents
DOCUMENTS_STORAGE_BUCKET=precheck-documents

# ── Embeddings (comment in when pgvector is ready) ────────────
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536

# ── LLM Rule Extraction (comment in when LangGraph is wired) ──
# OPENAI_API_KEY=          (same key as above)
# LLM_MODEL=gpt-4o-mini
# RULE_EXTRACTION_CONFIDENCE_THRESHOLD=0.6

# ── Speckle ───────────────────────────────────────────────────
# SPECKLE_SERVER_URL=https://app.speckle.systems
# SPECKLE_TOKEN=your-personal-access-token
