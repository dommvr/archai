# ============================================================
# ArchAI — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# Supabase — Required for auth and database
# Find these in your Supabase project settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================================
# Future integration variables (not needed at scaffold stage)
# ============================================================

# FastAPI backend URL (set when backend is deployed)
# NEXT_PUBLIC_API_URL=http://localhost:8000

# Replicate API token (for AI image/model generation)
# REPLICATE_API_TOKEN=your-replicate-token

# Speckle server URL and token (for viewer and export)
# NEXT_PUBLIC_SPECKLE_SERVER_URL=https://speckle.xyz
# SPECKLE_TOKEN=your-speckle-token

# Mapbox token (for Site Context map modal — parcel picker, geocoding, jurisdiction layers)
# Get your token at https://account.mapbox.com/ — create a public token with default scopes
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_public_token_here
